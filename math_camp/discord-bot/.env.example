# Copy to .env and fill in. Never commit the real .env.
DISCORD_TOKEN=
BOT_API_TOKEN=
CAMP_API_BASE=https://highergradetutoring.ca
GUILD_ID=
POLL_INTERVAL_SECONDS=120

# ── Sponsor email campaign ────────────────────────────────────────────
# Zoho mailbox (login + APP password — not your normal password)
ZOHO_EMAIL=
ZOHO_PASSWORD=
FROM_EMAIL=info@highergradetutoring.ca
# Google Sheet (service-account JSON must be deployed next to the bot, or set
# SHEETS_KEY_FILE to its absolute path). Sheet is shared with that account.
SHEETS_KEY_FILE=service_account.json
SPREADSHEET_ID=1rpxeQHzEVRJXAeICNcdvJdFHeTul9p-LIVOBhlRx47o
WORKSHEET_NAME=Sponsor Tracker
HEADER_ROW=4
# Set to 1 for a safe dry run (emails go to ZOHO_EMAIL, sheet untouched).
EMAILER_TEST_MODE=0
# Inbound reply review
IMAP_HOST=imap.zoho.com
IMAP_PORT=993
IMAP_FOLDER=INBOX
SMTP_HOST=smtp.zohocloud.ca
SMTP_PORT=465
REVIEW_CHANNEL_ID=
REPLY_POLL_SECONDS=120
# Role allowed to run /queue-* commands (besides Manage Server admins). Optional.
CONTROL_ROLE_ID=
